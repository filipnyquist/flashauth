{
  "name": "flashauth",
  "version": "0.1.0",
  "author": "Filip Nyquist",
  "main": "dist/index.js",
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.18"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "description": "Ultra-Fast JWT Authentication Framework for Bun.js and Elysia.js",
  "engines": {
    "bun": ">=1.1.0"
  },
  "keywords": [
    "authentication",
    "paseto",
    "elysia",
    "bun",
    "security",
    "jwt-alternative",
    "permissions",
    "session",
    "token"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "benchmark": "bun run benchmarks/token-operations.ts",
    "benchmark:server": "bun run benchmarks/benchmark-server.ts",
    "generate-schema": "bun run src/schema/generate.ts",
    "dev": "bun run --watch examples/basic-app.ts",
    "lint": "tsc --noEmit"
  },
  "type": "module",
  "types": "dist/index.d.ts",
  "dependencies": {
    "@simplewebauthn/server": "^13.2.2",
    "jose": "^6.1.3",
    "otplib": "^12.0.1"
  }
}
